<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-create-user-table" author="transaction-aggregation">
        <createTable tableName="app_user">
            <column name="user_id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="country" type="varchar(10)">
                <constraints nullable="false"/>
            </column>
            <column name="id_type" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="id_reference" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="app_user"
                baseColumnNames="user_id"
                constraintName="fk_user_sso"
                referencedTableName="sso"
                referencedColumnNames="user_id"/>
    </changeSet>

</databaseChangeLog>
